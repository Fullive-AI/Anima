{
  "name": "anima",
  "version": "0.1.0",
  "private": true,
  "description": "Make Every Hardware Intelligent",
  "scripts": {
    "dev": "concurrently --kill-others --success first -n broker,backend,frontend -c yellow,blue,green \"uv run amqtt -c amqtt.yaml\" \"uv run python -m core.main\" \"pnpm --filter dashboard dev\"",
    "dev:frontend": "pnpm --filter dashboard dev",
    "dev:backend": "uv run python -m core.main",
    "dev:broker": "uv run amqtt -c amqtt.yaml",
    "build": "pnpm --filter dashboard build",
    "postinstall": "uv sync --extra dev --python 3.13"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "playwright": "^1.59.1"
  }
}
